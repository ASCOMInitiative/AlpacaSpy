@page "/setup"
@inject State state
@inject Settings settings
@inject AlpacaSpyLogger logger
@inject IJSRuntime JSRuntime
@inject DialogService DialogService
@using ASCOM.Alpaca.Discovery
@using ASCOM.Common.Interfaces
@using ASCOM.Common.Alpaca

@implements IAsyncDisposable

<PageTitle>@Globals.APPLICATION_NAME - Setup</PageTitle>
<h3>Device Discovery and Configuration</h3>
@if (state.Connected)
{
    <div style="margin-top:20px;margin-bottom:20px;font-weight:bold;font-size:large; color:red;">Device state must be "Disconnected" in order to configure Proxy devices.</div>
}
<p>@state.StatusText</p>

<div style="margin-bottom:16px;">
    <RadzenButton Click="RunDiscoveryAsync"
                  Text="Discover and select Alpaca devices"
                  ButtonStyle="ButtonStyle.Primary"
                  Style="border-radius:20px; text-transform:none;"
                  Disabled="@(_discoveryRunning || state.Connected)" />

    @if (_discoveryRunning)
    {
        <span style="margin-left:12px;">Searching for Alpaca devices...</span>
    }

    <div style="margin-left:auto;display:flex;gap:8px;justify-content:flex-end;">
        <RadzenButton Click="ClearDiscoveredDevicesAsync"
                      Text="Clear discovered device list"
                      ButtonStyle="ButtonStyle.Warning"
                      Style="border-radius:20px; text-transform:none;"
                      Disabled="@(_discoveryRunning)" />

        <RadzenButton Click="DeleteAllConfiguredDevicesAsync"
                      Text="Delete all configured devices"
                      ButtonStyle="ButtonStyle.Danger"
                      Style="border-radius:20px; text-transform:none;"
                      Disabled="@(_discoveryRunning || state.Connected)" />
    </div>
</div>

@if (state.DiscoveredDevices.Any())
{
    <h4>Discovered Devices</h4>
    <RadzenDataGrid Data="@state.DiscoveredDevices" TItem="ASCOM.Alpaca.Discovery.AscomDevice" AllowPaging="false" AllowSorting="true">
        <Columns>
            <RadzenDataGridColumn TItem="ASCOM.Alpaca.Discovery.AscomDevice" Property="AscomDeviceName" Title="Name" Width="200px" />
            <RadzenDataGridColumn TItem="ASCOM.Alpaca.Discovery.AscomDevice" Property="AscomDeviceType" Title="Type" Width="120px" />
            <RadzenDataGridColumn TItem="ASCOM.Alpaca.Discovery.AscomDevice" Property="IpAddress" Title="IP Address" Width="140px" />
            <RadzenDataGridColumn TItem="ASCOM.Alpaca.Discovery.AscomDevice" Property="IpPort" Title="Port" Width="80px" />
            <RadzenDataGridColumn TItem="ASCOM.Alpaca.Discovery.AscomDevice" Title="Actions" Width="120px">
                <Template Context="device">
                    <RadzenButton Click="@(() => AddDevice(device))"
                                  Text="Add"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Size="ButtonSize.Small"
                                  Disabled="@(settings.ConfiguredDevices.Count >= Globals.MAX_CONFIGURED_DEVICES || state.Connected)" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

<h4 style="margin-top:24px;">Settings</h4>
<RadzenTabs>
    <Tabs>
        <RadzenTabsItem Text="Settings">
            <div style="display:flex;flex-direction:column;gap:8px;max-width:400px;">
                <div style="display:flex;align-items:center;gap:8px;">
                    <RadzenCheckBox TValue="bool"
                                    Value="_autoConnect"
                                    ValueChanged="@((bool v) => { _autoConnect = v; SaveSettings(); })"
                                    Name="autoConnect" />
                    <label>Auto-connect on startup</label>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <label style="width:160px;">Server Port:</label>
                    <RadzenNumeric TValue="int"
                                   @bind-Value="_serverPort"
                                   Min="1024"
                                   Max="65535"
                                   Change="@(() => SaveSettings())"
                                   Style="width:100px;" />
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <label style="width:160px;">Logging Level:</label>
                    <RadzenDropDown TValue="ASCOM.Common.Interfaces.LogLevel"
                                    Data="@_logLevels"
                                    @bind-Value="_logLevel"
                                    Style="width:180px;"
                                    Change="@(() => SaveSettings())" />
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <label style="width:160px;">Location:</label>
                    <RadzenTextBox TValue="string"
                                   Value="@settings.Location"
                                   ValueChanged="@((string v) => { settings.Location = v; SaveSettings(); })"
                                   Style="width:220px;" />
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <RadzenCheckBox TValue="bool"
                                    Value="@settings.LogDiscoveryMessages"
                                    ValueChanged="@((bool v) => { settings.LogDiscoveryMessages = v; SaveSettings(); })"
                                    Name="logDiscoveryMessages" />
                    <label>Log discovery messages</label>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <RadzenCheckBox TValue="bool"
                                    Value="@settings.StartBrowserOnLaunch"
                                    ValueChanged="@((bool v) => { settings.StartBrowserOnLaunch = v; SaveSettings(); })"
                                    Name="startBrowserOnLaunch" />
                    <label>Start browser on launch</label>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <label style="width:160px;">Discovery duration:</label>
                    <RadzenNumeric TValue="double"
                                   Value="@settings.AlpacaDiscoveryDuration"
                                   ValueChanged="@((double v) => { settings.AlpacaDiscoveryDuration = v; SaveSettings(); })"
                                   Min="1"
                                   Style="width:100px;" />
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <label style="width:160px;">Get timeout:</label>
                    <RadzenNumeric TValue="int"
                                   Value="@settings.AlpacaGetPropertyTimeout"
                                   ValueChanged="@((int v) => { settings.AlpacaGetPropertyTimeout = v; SaveSettings(); })"
                                   Min="1"
                                   Style="width:100px;" />
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <label style="width:160px;">Connect timeout:</label>
                    <RadzenNumeric TValue="int"
                                   Value="@settings.AlpacaConnectTimeout"
                                   ValueChanged="@((int v) => { settings.AlpacaConnectTimeout = v; SaveSettings(); })"
                                   Min="1"
                                   Style="width:100px;" />
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <RadzenCheckBox TValue="bool"
                                    Value="@settings.IncludeAlpacaTrace"
                                    ValueChanged="@((bool v) => { settings.IncludeAlpacaTrace = v; SaveSettings(); })"
                                    Name="includeAlpacaTrace" />
                    <label>Include Alpaca trace</label>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <RadzenCheckBox TValue="bool"
                                    Value="@settings.BindToAllNetworkAddresses"
                                    ValueChanged="@((bool v) => { settings.BindToAllNetworkAddresses = v; SaveSettings(); })"
                                    Name="bindToAllNetworkAddresses" />
                    <label>Bind to all network addresses</label>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <RadzenCheckBox TValue="bool"
                                    Value="@settings.AllowDiscovery"
                                    ValueChanged="@((bool v) => { settings.AllowDiscovery = v; SaveSettings(); })"
                                    Name="allowDiscovery" />
                    <label>Allow discovery</label>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <RadzenCheckBox TValue="bool"
                                    Value="@settings.DiscoveryResponseOnlyOnLocalHost"
                                    ValueChanged="@((bool v) => { settings.DiscoveryResponseOnlyOnLocalHost = v; SaveSettings(); })"
                                    Name="discoveryResponseOnlyOnLocalHost" />
                    <label>Discovery response only on local host</label>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                    <RadzenCheckBox TValue="bool"
                                    Value="@settings.RunInStrictAlpacaMode"
                                    ValueChanged="@((bool v) => { settings.RunInStrictAlpacaMode = v; SaveSettings(); })"
                                    Name="runInStrictAlpacaMode" />
                    <label>Run in strict Alpaca mode</label>
                </div>
            </div>
        </RadzenTabsItem>

        @foreach (ConfiguredDevice device in settings.ConfiguredDevices)
        {
            // Get a list of all members
            List<SelectiveLogMember> members = SelectiveLoggingMetadata.GetMembers(device.DeviceType).ToList();

            // Get the number of columns required for this device type,
            int numberOfColumns = Globals.DevicetypeDisplayColumns.TryGetValue(device.DeviceType, out int cols) ? cols : 1;

            // Calculate the number of items per column, rounding up to ensure all items are included
            int splitIndex = (members.Count + numberOfColumns - 1) / numberOfColumns;

            // Create a dictionary to hold the members for each column
            Dictionary<int, List<SelectiveLogMember>> columns = new();
            for (int i = 0; i < numberOfColumns; i++)
            {
                columns[i] = members.Skip(i * splitIndex).Take(splitIndex).ToList();
            }

            string styleText = $"border:1px solid #ccc;padding:12px;border-radius:4px;max-width:{(numberOfColumns == 1 ? 700 : 60 + 270 * numberOfColumns)}px;";

            <RadzenTabsItem Text="@($"{device.Name} ({device.DeviceType})")" @key="device.UniqueId">
                <div style=@styleText>
                    <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;">
                        <strong>@device.Name (@device.DeviceType)</strong>
                        <span style="color:gray;font-size:small;">@device.IpAddress:@device.PortNumber / Device @device.RemoteDeviceNumber</span>
                        <RadzenButton Click="@(() => RemoveDevice(device))"
                                      Text="Remove"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Style="border-radius:16px; text-transform:none;"
                                      Size="ButtonSize.Small"
                                      Disabled="@state.Connected" />
                    </div>
                    <div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:8px;align-items:center;">
                        <RadzenCheckBox Value="device.LogClientHeaders"
                                        ValueChanged="@((bool v) => { device.LogClientHeaders = v; settings.Save(); })"
                                        Name="@($"lch_{device.UniqueId}")" />
                        <label>Log client headers</label>
                        <RadzenCheckBox Value="device.LogClientParams"
                                        ValueChanged="@((bool v) => { device.LogClientParams = v; settings.Save(); })"
                                        Name="@($"lcq_{device.UniqueId}")" />
                        <label>Log client parameters</label>
                        <RadzenCheckBox Value="device.LogDeviceHeaders"
                                        ValueChanged="@((bool v) => { device.LogDeviceHeaders = v; settings.Save(); })"
                                        Name="@($"ldh_{device.UniqueId}")" />
                        <label>Log device headers</label>
                        <RadzenCheckBox Value="device.LogJsonParameters"
                                        ValueChanged="@((bool v) => { device.LogJsonParameters = v; settings.Save(); })"
                                        Name="@($"ljp_{device.UniqueId}")" />
                        <label>Log JSON parameters</label>
                    </div>
                    <div style="margin-top:16px;">
                        <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;">
                            <strong style="margin-right:auto;">Selective logging</strong>
                            <RadzenButton Click="@(() => ClearAllSelected(device))"
                                          Text="Clear All"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Style="border-radius:16px; text-transform:none;"
                                          Size="ButtonSize.Small" />
                            <RadzenButton Click="@(() => SetAllSelected(device))"
                                          Text="Set All"
                                          ButtonStyle="ButtonStyle.Primary"
                                          Style="border-radius:16px; text-transform:none;"
                                          Size="ButtonSize.Small" />
                        </div>

                        <div style="margin-top:8px;display:flex;gap:24px;align-items:flex-start;">
                            <div style="flex:1;min-width:270px;">
                                @foreach (SelectiveLogMember member in columns[0])
                                {
                                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;font-size:14px;">
                                        <RadzenCheckBox TValue="bool"
                                                        Value="@SelectiveLoggingMetadata.IsMemberEnabled(device, member)"
                                                        ValueChanged="@((bool v) => UpdateMemberLogging(device, member, v))"
                                                        Name="@($"{device.UniqueId}_{member.SelectionKey}")" />
                                        <label>@member.DisplayName</label>
                                    </div>
                                }
                            </div>
                            @if (numberOfColumns > 1)
                            {
                                <div style="flex:1;min-width:270px;">
                                    @foreach (SelectiveLogMember member in columns[1])
                                    {
                                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;font-size:14px;">
                                            <RadzenCheckBox TValue="bool"
                                                            Value="@SelectiveLoggingMetadata.IsMemberEnabled(device, member)"
                                                            ValueChanged="@((bool v) => UpdateMemberLogging(device, member, v))"
                                                            Name="@($"{device.UniqueId}_{member.SelectionKey}")" />
                                            <label>@member.DisplayName</label>
                                        </div>
                                    }
                                </div>
                            }
                            @if (numberOfColumns > 2)
                            {
                                <div style="flex:1;min-width:270px;">
                                    @foreach (SelectiveLogMember member in columns[2])
                                    {
                                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;font-size:14px;">
                                            <RadzenCheckBox TValue="bool"
                                                            Value="@SelectiveLoggingMetadata.IsMemberEnabled(device, member)"
                                                            ValueChanged="@((bool v) => UpdateMemberLogging(device, member, v))"
                                                            Name="@($"{device.UniqueId}_{member.SelectionKey}")" />
                                            <label>@member.DisplayName</label>
                                        </div>
                                    }
                                </div>
                            }
                            @if (numberOfColumns > 3)
                            {
                                <div style="flex:1;min-width:270px;">
                                    @foreach (SelectiveLogMember member in columns[3])
                                    {
                                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;font-size:14px;">
                                            <RadzenCheckBox TValue="bool"
                                                            Value="@SelectiveLoggingMetadata.IsMemberEnabled(device, member)"
                                                            ValueChanged="@((bool v) => UpdateMemberLogging(device, member, v))"
                                                            Name="@($"{device.UniqueId}_{member.SelectionKey}")" />
                                            <label>@member.DisplayName</label>
                                        </div>
                                    }
                                </div>
                            }
                            @if (numberOfColumns > 4)
                            {
                                <div style="flex:1;min-width:270px;">
                                    @foreach (SelectiveLogMember member in columns[4])
                                    {
                                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;font-size:14px;">
                                            <RadzenCheckBox TValue="bool"
                                                            Value="@SelectiveLoggingMetadata.IsMemberEnabled(device, member)"
                                                            ValueChanged="@((bool v) => UpdateMemberLogging(device, member, v))"
                                                            Name="@($"{device.UniqueId}_{member.SelectionKey}")" />
                                            <label>@member.DisplayName</label>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </RadzenTabsItem>
        }
    </Tabs>
</RadzenTabs>

@code {
    private bool _discoveryRunning;
    private int _serverPort;
    private bool _autoConnect;
    private LogLevel _logLevel;
    private readonly LogLevel[] _logLevels = Enum.GetValues<LogLevel>();

    protected override void OnInitialized()
    {
        _serverPort = settings.ServerPort;
        _logLevel = settings.LogLevel;
        _autoConnect = settings.AutoConnect;
        state.ConfiguredDevices = settings.ConfiguredDevices.ToList();
        state.StateChanged += OnStateChanged;
        settings.ConfigurationChanged += OnStateChanged;
        state.StatusText = ""; // Clear status text on entry.
    }

    private async Task RunDiscoveryAsync()
    {
        _discoveryRunning = true;
        state.StatusText = "Discovery running...";
        await InvokeAsync(StateHasChanged);
        try
        {
            // Get a list of devices that are available on the network
            List<AscomDevice> devices = await AlpacaDiscovery.GetAscomDevicesAsync(null, 1, 100, 32227, settings.AlpacaDiscoveryDuration, false, true, false, ServiceType.Http, settings.LogLevel < LogLevel.Information ? logger : null, CancellationToken.None);

            // Remove our own AlpacaSpy devices from the list, we don't want to proxy ourselves!
            devices.RemoveAll(d => d.AscomDeviceName.StartsWith(Globals.APPLICATION_SHORT_NAME));

            // Update the list of discovered devices
            lock (state.DiscoveredDevicesLock)
            {
                state.DiscoveredDevices.Clear();
                state.DiscoveredDevices.AddRange(devices);
            }

            // Log the completion
            state.DiscoveryHasRun = true;
            state.StatusText = $"Found {state.DiscoveredDevices.Count} device(s) at {DateTime.Now:HH:mm:ss}.";
            logger.LogMessage("Discovery", $"Found {state.DiscoveredDevices.Count} Alpaca device(s).");
        }
        catch (Exception ex)
        {
            state.StatusText = $"Discovery error: {ex.Message}";
            logger.LogError("Discovery", $"Exception: {ex.Message}");
        }
        finally
        {
            _discoveryRunning = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteAllConfiguredDevicesAsync()
    {
        if (state.Connected)
            return;

        bool? confirmed = await DialogService.Confirm(
            "Are you sure you want to delete all configured devices? This action cannot be undone, restart required.",
            "Confirm Delete All",
            new ConfirmOptions { OkButtonText = "Delete All", CancelButtonText = "Cancel" });

        if (confirmed != true)
            return;

        settings.ConfiguredDevices.Clear();
        state.ConfiguredDevices.Clear();
        settings.Save();
        state.StatusText = "All configured devices have been cleared.";
        state.DisplayRestartMessage = true;
    }

    private async Task ClearDiscoveredDevicesAsync()
    {
        state.DiscoveredDevices.Clear();
        state.DiscoveryHasRun = true;
        state.StatusText = $"Cleared discovered devices at {DateTime.Now:HH:mm:ss}.";
        logger.LogMessage("Discovery", $"Cleared discovered Alpaca device(s).");
    }

    private async Task ClearAllSelected(ConfiguredDevice device)
    {
        SelectiveLoggingMetadata.ClearAllMembers(device);
        settings.Save();
    }

    private async Task SetAllSelected(ConfiguredDevice device)
    {
        SelectiveLoggingMetadata.EnableAllMembers(device, device.DeviceType);
        settings.Save();
    }

    private async Task AddDevice(AscomDevice device)
    {
        if (settings.ConfiguredDevices.Count >= Globals.MAX_CONFIGURED_DEVICES)
            return;

        if (device.AscomDeviceType is null || !Enum.TryParse<AlpacaDeviceType>(device.AscomDeviceType.Value.ToString(), true, out AlpacaDeviceType deviceType))
            return;

        int nextNumber = settings.ConfiguredDevices
            .Where(d => d.DeviceType == deviceType)
            .Select(d => d.ProxyDeviceNumber)
            .DefaultIfEmpty(-1)
            .Max() + 1;

        ConfiguredDevice newDevice = new()
        {
            Name = device.AscomDeviceName,
            IpAddress = device.IpAddress.ToString(),
            PortNumber = device.IpPort,
            RemoteDeviceNumber = device.AlpacaDeviceNumber,
            DeviceType = deviceType,
            ProxyDeviceNumber = nextNumber,
            UniqueId = Guid.NewGuid().ToString(),
            EnabledLogMembers = SelectiveLoggingMetadata.GetSelectionKeys(deviceType).ToList()
        };

        settings.ConfiguredDevices.Add(newDevice);
        state.ConfiguredDevices = settings.ConfiguredDevices.ToList();
        settings.Save();
        state.DisplayRestartMessage = true;
        state.StatusText = $"Added {newDevice.Name}. Restart required for changes to take effect.";
    }

    private async Task RemoveDevice(ConfiguredDevice device)
    {
        bool? confirmed = await DialogService.Confirm(
            "Are you sure you want to remove this device? This action cannot be undone, restart required.",
            "Confirm Remove",
            new ConfirmOptions { OkButtonText = "Remove", CancelButtonText = "Cancel" });

        if (confirmed != true)
            return;

        settings.ConfiguredDevices.Remove(device);
        // Renumber remaining devices of the same type to ensure contiguous numbering, starting at 0
        foreach (AlpacaDeviceType type in Enum.GetValues<AlpacaDeviceType>())
        {
            int idx = -1;
            foreach (ConfiguredDevice configuredDevice in settings.ConfiguredDevices.Where(d => d.DeviceType == type))
            {
                // Increment the index to the next value. Since it is initialised to -1, the first device of each type will be set to 0
                idx++;
                // Check whether the device's proxy number matches the expected value. If not, update it and mark that a restart is required to apply the change
                if (configuredDevice.ProxyDeviceNumber != idx)
                {
                    configuredDevice.ProxyDeviceNumber = idx;
                }
            }
        }
        // Update the state and save settings
        state.ConfiguredDevices = settings.ConfiguredDevices.ToList();
        settings.Save();

        state.DisplayRestartMessage = true;
        state.StatusText = $"Removed {device.Name}. Restart required for changes to take effect.";
    }

    private void SaveSettings()
    {
        bool restartRequired = settings.ServerPort != _serverPort;
        settings.AutoConnect = _autoConnect;
        settings.ServerPort = (ushort)_serverPort;
        settings.LogLevel = _logLevel;
        logger.SetMinimumLoggingLevel(_logLevel);
        settings.Save();
        if (restartRequired)
            state.DisplayRestartMessage = true;
        state.StatusText = $"Settings saved at {DateTime.Now:HH:mm:ss}.";
    }

    private void UpdateMemberLogging(ConfiguredDevice device, SelectiveLogMember member, bool enabled)
    {
        SelectiveLoggingMetadata.SetMemberEnabled(device, member, enabled);
        settings.Save();
    }

    private async void OnStateChanged(object? sender, EventArgs e)
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    public ValueTask DisposeAsync()
    {
        state.StateChanged -= OnStateChanged;
        settings.ConfigurationChanged -= OnStateChanged;
        return ValueTask.CompletedTask;
    }
}
