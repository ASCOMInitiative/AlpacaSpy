@page "/"
@inject State state
@inject AlpacaSpyLogger logger
@inject IJSRuntime JSRuntime
@inject Settings settings

@implements IAsyncDisposable

<PageTitle>@Globals.APPLICATION_NAME</PageTitle>

<div>
    <span>
        <RadzenButton Click="ClearScreen"
                      Text="Clear screen"
                      ButtonStyle="ButtonStyle.Primary"
                      Style="border-radius:20px; text-transform:none;"/>
    </span>
    <span>
        <RadzenButton Click="OnCancelButtonPressed"
                      Text="Cancel Playback"
                      ButtonStyle="ButtonStyle.Danger"
                      Style="border-radius:20px; text-transform:none;" />
    </span>
    <span>
        @settings.Status
    </span>
    <p />
</div>

<div style="height: calc(100vh - 9rem); min-height: 200px;">
    <RadzenTextArea Id="AlpacaSpyLog"
                    Style='font-family: "Lucida Console", "Courier New", monospace; font-size: 14px; line-height: 18px; padding-bottom: 0px; width:100%; height:100%;'
                    Name="AlpacaSpyLog"
                    @bind-Value=@ApplicationLog
                    Cols="250" ReadOnly=true />
</div>

@code
{
    CancellationTokenSource cancelAlpacaSpy = new CancellationTokenSource();

    private bool _disposed;
    private bool _logContentChanged;
    private int _lastLogLength;
    private string _cachedLogText = string.Empty;
    private readonly CancellationTokenSource _cts = new();
    private DotNetObjectReference<Index>? objRef;

    private async Task OnCancelButtonPressed()
    {
        cancelAlpacaSpy.Cancel();
    }
    
    private async Task ClearScreen()
    {
        logger.ClearScreen();
        _cachedLogText = string.Empty;
        _lastLogLength = 0;
        await InvokeAsync(StateHasChanged);
    }

    protected override void OnInitialized()
    {
        state.CancellationToken = cancelAlpacaSpy.Token;
        state.StateChanged += OnStateChanged;
        settings.ConfigurationChanged += OnStateChanged;

        lock (Globals.writeLogLock)
        {
            _cachedLogText = state.ApplicationLog.ToString();
        }
        _lastLogLength = state.ApplicationLog.Length;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = LogRefreshLoopAsync(_cts.Token);

            try
            {
                objRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("window.registerIndexViewportChangeCallback", objRef);
                logger.LogBlankLine();
                await ScrollLogToBottomAsync();
            }
            catch (InvalidOperationException ex)
            {
                logger.LogWarning("Index", $"Interactive startup is not ready: {ex.Message}");
            }
            catch (JSDisconnectedException)
            {
            }
            catch (TaskCanceledException)
            {
            }
        }

        if (_logContentChanged)
        {
            _logContentChanged = false;
            await ScrollLogToBottomAsync();
        }
    }

    private async Task ConnectDisconnectAsync()
    {
        try
        {
            state.OperationUnderway = true;
            await ConnectionManager.ChangeConnectedStateAsync(state, settings, logger, () => InvokeAsync(StateHasChanged));
        }
        finally
        {
            state.OperationUnderway = false;
        }
    }

    private async Task LogRefreshLoopAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(Globals.LOG_REFRESH_INTERVAL, token);

                int currentLength = state.ApplicationLog.Length;
                if (currentLength != _lastLogLength)
                {
                    _lastLogLength = currentLength;
                    lock (Globals.writeLogLock)
                    {
                        _cachedLogText = state.ApplicationLog.ToString();
                    }
                    _logContentChanged = true;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (TaskCanceledException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private string ApplicationLog
    {
        get => _cachedLogText;
        set
        {
        }
    }

    private async void OnStateChanged(object? sender, EventArgs e)
    {
        if (_disposed)
            return;

        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
        }
        catch (Exception ex)
        {
            LogConsole(ex.Message);
        }
    }

    private void LogConsole(string message)
    {
        lock (Globals.writeLogLock)
        {
            Console.Write(DateTime.Now.ToString("HH:mm:ss.fff"));
            Console.ForegroundColor = ConsoleColor.DarkCyan;
            Console.WriteLine(message);
            Console.ResetColor();
        }
    }

    [JSInvokable]
    public async Task OnResizeIndex(int width, int height)
    {
        try
        {
            await InvokeAsync(StateHasChanged);
            await ScrollLogToBottomAsync();
        }
        catch (Exception ex)
        {
            logger.LogError("OnResize", $"Exception - {ex.Message}\r\n{ex}");
        }
    }

    private async Task ScrollLogToBottomAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("ScrollToBottom", "AlpacaSpyLog");
        }
        catch (InvalidOperationException ex)
        {
            logger.LogWarning("Index", $"Log scroll is not ready: {ex.Message}");
        }
        catch (JSDisconnectedException)
        {
        }
        catch (TaskCanceledException)
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _cts.Cancel();
        _cts.Dispose();
        state.StateChanged -= OnStateChanged;
        settings.ConfigurationChanged -= OnStateChanged;

        if (objRef != null)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("window.unregisterIndexViewportChangeCallback");
            }
            catch (InvalidOperationException ex)
            {
                logger.LogWarning("Index", $"Viewport cleanup is not ready: {ex.Message}");
            }
            catch (JSDisconnectedException)
            {
            }
            catch (TaskCanceledException)
            {
            }
            objRef.Dispose();
        }
    }
}
