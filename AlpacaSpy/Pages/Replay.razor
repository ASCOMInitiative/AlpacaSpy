@page "/filebrowser"
@using ASCOM.Tools
@using ASCOM.Common
@using System.Text.Json
@using System.Text.RegularExpressions

@inject FileBrowserService Browser
@inject NavigationManager Navigation
@inject AlpacaSpyLogger Logger
@inject State State
@inject IHttpClientFactory HttpClientFactory
@inject DialogService DialogService
@inject Settings Settings

<style>
    .title-row {
        display: flex;
        align-items: center; /* vertically aligns the span with the h4 */
        gap: 8px; /* optional spacing */
    }

    .right-text {
        margin-left: 0; /* pushes the span all the way to the right */
    }

    .file-browser {
        position: relative;
    }

    .file-browser-content {
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .breadcrumb-bar {
        width: 100%;
        margin-bottom: 12px;
    }
    /* shared font size so directory labels and file list items match */
    :root {
        --dir-font-size: 14px;
    }

    .directory-tree .expander {
        width: 18px;
        height: 18px;
        padding: 0;
        margin-right: 6px;
        font-size: 12px;
        line-height: 1;
        vertical-align: middle;
    }

    .directory-tree .expander-placeholder {
        display: inline-block;
        width: 18px;
        height: 18px;
        margin-right: 6px;
    }

    .directory-tree .node-label {
        vertical-align: middle;
        cursor: pointer;
        display: inline-block;
        font-size: var(--dir-font-size);
    }

    .directory-tree .children {
        margin-left: 12px;
    }

    .tree-node {
        margin: 2px 0;
    }

    /* Floating JSON file list box (top-right) */
    .directory-tree {
        flex: 1 1 auto;
        overflow: auto;
        max-height: calc(100vh - 160px);
        border: 1px solid #d0d0d0;
        padding: 8px;
        border-radius: 6px;
        background: #ffffff;
    }

    .file-list-box {
        /* Render as a fixed right-hand column next to the directory tree */
        flex: 0 0 340px;
        width: 340px;
        /* ensure it never exceeds viewport height */
        max-height: calc(100vh - 24px);
        overflow: auto;
        background: #ffffff;
        border: 1px solid #d0d0d0; /* thin bounding line */
        padding: 8px;
        border-radius: 6px;
        box-shadow: none;
        font-size: var(--dir-font-size);
    }

        .file-list-box h3 {
            margin: 0 0 6px 0;
            font-size: var(--dir-font-size);
        }

        .file-list-box .path {
            font-size: var(--dir-font-size);
            color: #666;
            margin-bottom: 6px;
            word-break: break-all;
        }

        .file-list-box ul {
            margin: 0;
            padding-left: 16px;
            list-style: disc;
        }

        .file-list-box li {
            padding: 4px 0;
            border-bottom: 1px dashed #f0f0f0;
            font-size: var(--dir-font-size);
        }
</style>

<PageTitle>@Globals.APPLICATION_NAME - Replay Recordings</PageTitle>

<h3>Replay Recordings</h3>

<h4>Select Target Device</h4>

<div class="target-device-list">
    @if (State.ConfiguredDevices != null && State.ConfiguredDevices.Any())
    {
        @foreach (var device in State.ConfiguredDevices)
        {
            <div>
                <input type="radio" name="targetDevice" id="@device.UniqueId" checked="@(State.ReplayTargetDevice?.UniqueId == device.UniqueId)" @onchange="() => SelectTargetDevice(device)" />
                <label for="@device.UniqueId">@($"{device.DeviceType}/{device.ProxyDeviceNumber} {device.IpAddress}")</label>
            </div>
        }
    }
    else
    {
        <div>No configured devices</div>
    }
</div>

<div class="title-row" style="margin-top:36px;">
    <h4>Select Replay File</h4>
    @if (State.ReplayTargetDevice is null)
    {
        <span class="right-text" style="color:red">(Select target device first)</span>
    }
</div>

<div class="file-browser">

    <!-- Breadcrumb + Buttons -->
    <div class="breadcrumb-bar">
        <RadzenButton Text="⬆ Up one level"
                      Click="@GoUpOneLevel"
                      Style="border-radius:20px; text-transform:none;"
                      Disabled="@(string.IsNullOrEmpty(SelectedPath) || State.ReplayTargetDevice is null )" />
        <RadzenButton Text="Documents"
                      Disabled="@(State.ReplayTargetDevice is null )"
                      Click="@ShowDocuments"
                      Style="margin-left:8px; border-radius:20px; text-transform:none;" />
        <RadzenButton Text="Disks"
                      Disabled="@(State.ReplayTargetDevice is null )"
                      Click="@ShowDisks"
                      Style="margin-left:8px; border-radius:20px; text-transform:none;" />
        <RadzenButton Text="ASCOM Logs"
                      Disabled="@(State.ReplayTargetDevice is null )"
                      Click="@ShowAscomLogsClickHandler"
                      Style="margin-left:8px; border-radius:20px; text-transform:none;" />
        <span style="margin-left:48px;min-width:205px;">
            <RadzenCheckBox Value="Settings.PlaybackExpandJson"
                            ValueChanged="@((bool v) => { Settings.PlaybackExpandJson = v;})" />
            <label>Pretty-print JSON on playback.</label>
        </span>

        <span class="breadcrumb" style="margin-top:12px;">
            @foreach (var part in BreadcrumbParts)
            {
                <span class="crumb" @onclick="() => NavigateTo(part.FullPath)">
                    @part.Name
                </span>
                @if (part != BreadcrumbParts.Last() && part != BreadcrumbParts.First())
                {
                    @if (OperatingSystem.IsWindows())
                    {
                        <span>\</span>
                    }
                    else
                    {
                        <span>/</span>
                    }
                }
            }
        </span>
    </div>

    <!-- Directory Tree -->
    <div class="file-browser-content" style="display:@(State.ReplayTargetDevice is null ? "none" : "flex")">
        <div class="directory-tree">
            @if (baseIsDisks)
            {
                @foreach (var drive in DriveInfo.GetDrives())
                {
                    var drivePath = drive.Name;
                    <div class="tree-node">
                        <button class="expander" @onclick="() => ToggleExpand(drivePath)">@(IsExpanded(drivePath) ? "▼" : "▶")</button>
                        <span class="node-label" @onclick="() => SelectPath(drivePath)">@drivePath</span>
                        @if (IsExpanded(drivePath))
                        {
                            <div class="children" style="margin-left:16px">
                                @foreach (var dir in GetDirectoriesCached(drivePath))
                                {
                                    @RenderDirectory(dir)
                                }
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                // Show the currently selected path as the root of the visible tree when possible,
                // falling back to the configured baseRootPath (Documents or ASCOM Logs).
                var root = SelectedPath ?? baseRootPath ?? Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments);
                var displayName = Path.GetFileName(root.TrimEnd(Path.DirectorySeparatorChar));
                if (string.IsNullOrEmpty(displayName)) displayName = root;
                <div class="tree-node">
                    <button class="expander" @onclick="() => ToggleExpand(root)">@(IsExpanded(root) ? "▼" : "▶")</button>
                    <span class="node-label" @onclick="() => SelectPath(root)">@displayName</span>
                    @if (IsExpanded(root))
                    {
                        <div class="children" style="margin-left:16px">
                            @foreach (var dir in GetDirectoriesCached(root))
                            {
                                @RenderDirectory(dir)
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- File list -->
        <div class="file-list-box">
            <h3><b>JSON files</b></h3>
            <div class="path">@(SelectedPath is null ? "No folder selected" : "")</div>
            @if (Files != null && Files.Any())
            {
                <div class="file-checklist">
                    @foreach (var file in Files)
                    {
                        <div class="file-item">
                            <input type="radio" name="jsonFiles" checked="@(State.ReplaySelectedFileFullName == file.FullName)" @onchange="@(e => OnFileRadioChanged(file.FullName, e))" />
                            <label>@file.Name</label>
                        </div>
                    }
                </div>
                <div style="margin-top:8px; text-align:right;">
                    <RadzenButton Text="Replay Transactions"
                                  Click="@ReplayTransactions"
                                  Style="margin-left:8px; border-radius:20px; text-transform:none;"
                                  Disabled="@(string.IsNullOrEmpty(State.ReplaySelectedFileFullName))" />
                    <div style="margin-top:8px;">
                        <RadzenProgressBar @bind-Value="@replayProgress" AriaLabel="Replay Progress" Style="width:240px;" />
                    </div>
                </div>
            }
            else
            {
                <div class="empty">No JSON files</div>
            }
        </div>
    </div>
</div>

@code {
    // Define replay mismatch message constants
    const string VALUES_DIFFERENT_MESSAGE = "ELEMENTS ARE DIFFERENT";
    const string ELEMENT_MISSING_IN_ONE_RESPONSE = "ELEMENT MISSING IN ONE RESPONSE";
    const string ELEMENT_MISSING_IN_BOTH_RESPONSES = "ELEMENT MISSING IN BOTH RESPONSES";
    static readonly string[] ReplayMismatchMessages = { VALUES_DIFFERENT_MESSAGE, ELEMENT_MISSING_IN_ONE_RESPONSE, ELEMENT_MISSING_IN_BOTH_RESPONSES };

    // Define the list of properties to compare between the original recording and the current device response
    static readonly string[] RESPONSE_PROPERTIES_TO_COMARE = { "Value", "ErrorNumber", "ErrorMessage" };

    // Define a variable to hold data on any mis-matches between the original recording and current device behaviour
    List<Mismatch> Mismatches = new();

    string? SelectedPath;
    List<System.IO.FileInfo> Files = new();

    // File path breadcrumb parts, each with a display name and full path for navigation
    record Crumb(string Name, string FullPath);
    List<Crumb> BreadcrumbParts = new();

    // Directory tree helpers
    Dictionary<string, List<string>> dirCache = new();
    HashSet<string> expanded = new();

    // Base mode: true = show disks (DriveInfo), false = show single baseRootPath (Documents)
    bool baseIsDisks = true;
    string? baseRootPath = null;

    // Variable to hold the current progress of the replay operation as a percentage
    double replayProgress = 0.0;

    /// <summary>
    /// Initialize the component.
    /// </summary>
    protected override void OnInitialized()
    {
        // Default to ASCOM Logs view if available
        ShowAscomLogs(false);
    }

    /// <summary>
    /// Entry point for replaying transactions from the selected JSON file.
    /// Creates a local variable <c>selectedFile</c> containing the selected file full path.
    /// Implementation is intentionally empty for now.
    /// </summary>
    async Task ReplayTransactions()
    {
        // Define variables to hold any mis-matches between the original recording and current device behaviour
        string sendLogMessage, responseLogMessage = string.Empty;

        // local variable containing the selected file name
        string? selectedFile = State.ReplaySelectedFileFullName;

        // Make sure the selected file really does exist
        if (string.IsNullOrEmpty(selectedFile) || !File.Exists(selectedFile))
        {
            Logger.LogError("ReplayTransactions", "No file selected or file does not exist.");
            return;
        }

        // Reset progress to 0
        replayProgress = 0.0;
        await InvokeAsync(StateHasChanged);

        // Play back recording
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var transactions = new List<AlpacaTransaction>();
            var totalTransactions = 0;

            // Determine the device type of the recorded file by opening it as a JSON document and extracting the device type from first URL entry
            Logger.LogMessage("ReplayTransactions", $"Starting initial parse");
            using (FileStream? countStream = new FileStream(selectedFile, FileMode.Open, FileAccess.Read, FileShare.Read)) // Open the file as a file stream
            using (var jsonDocument = await JsonDocument.ParseAsync(countStream)) // Read the file as a JSON document
            {
                // Check that the document does contain a JSON array
                if (jsonDocument.RootElement.ValueKind != System.Text.Json.JsonValueKind.Array) // No array found
                {
                    Logger.LogError("ReplayTransactions", "The selected JSON file does not contain a top-level array.");
                    await DialogService.Alert($"The selected JSON file does not contain a top-level array.", "Unable to Replay", null);
                    return;
                }

                // Get the overall number of entries so we can show the % progress
                totalTransactions = jsonDocument.RootElement.GetArrayLength();

                // Extract the string value of the "RequestUri" property from the first element of the top-level array, if present.
                string? firstRequestUri = null;
                if (totalTransactions > 0) // At least one array element in the JSOn file
                {
                    // Get the first element in the array
                    JsonElement firstElement = jsonDocument.RootElement[0];
                    // Check whether we can read the value of RequestUri in the first array element
                    if (firstElement.ValueKind == JsonValueKind.Object && firstElement.TryGetProperty("RequestUri", out var requestUriProp) && requestUriProp.ValueKind == JsonValueKind.String) // Found OK
                    {
                        // Get the request URI
                        firstRequestUri = requestUriProp.GetString();
                        Logger.LogDebug("ReplayTransactions", $"First RequestUri: {firstRequestUri}");

                        //Extract the device type from the URI using a regex
                        Regex r = new Regex(@"\/api\/v1\/(?<DeviceTypeString>.*?)\/.*?", RegexOptions.IgnoreCase);
                        var match = r.Match(firstRequestUri ?? string.Empty);

                        // Check whether we got a value
                        if (match.Success) // Got a match OK
                        {
                            // Extract the device type as a string
                            string deviceTypeString = match.Groups["DeviceTypeString"].Value;

                            // Convert the string device type to a DeviceTypes enum value
                            AlpacaDeviceType deviceType = Enum.Parse<AlpacaDeviceType>(deviceTypeString, true);

                            Logger.LogDebug("ReplayTransactions", $"Extracted device type: {deviceTypeString} {deviceType}");

                            if (deviceType != State.ReplayTargetDevice?.DeviceType)
                            {
                                Logger.LogError("ReplayTransactions", $"The device type of the replay file ({deviceType}) does not match the target device type ({State.ReplayTargetDevice?.DeviceType}).");
                                await DialogService.Alert($"The device type of the replay file ({deviceType}) does not match the target device type ({State.ReplayTargetDevice?.DeviceType}).", "Unable to Replay", null);
                                return;
                            }
                        }
                        else // Could not extract the device type from the URI
                        {
                            Logger.LogError("ReplayTransactions", $"Cannot extract the device type from the URI: {firstRequestUri}.");
                            await DialogService.Alert($"Cannot extract the device type from the URI: {firstRequestUri}.", "Unable to Replay", null);
                            return;
                        }
                    }
                    else // Cannot find a string value for RequestUri in the first array element
                    {
                        Logger.LogError("ReplayTransactions", $"Cannot find the value of RequestUri in the first array element in the JSON file.");
                        await DialogService.Alert($"Cannot find the value of RequestUri in the first array element in the JSON file.", "Unable to Replay", null);
                        return;
                    }
                }
                else // No array elements in the JSON file
                {
                    Logger.LogError("ReplayTransactions", $"The selected file has no entries to replay: {selectedFile}");
                    await DialogService.Alert($"The selected file has no entries to replay.", "Unable to Replay", null);
                    return;
                }
            }
            Logger.LogDebug("ReplayTransactions", $"Completed initial parse");

            // Now read in the file as an array of AlpacaTransactions
            using (FileStream? readFilestream = new FileStream(selectedFile, FileMode.Open, FileAccess.Read, FileShare.Read))
            {
                var processed = 0;
                await foreach (AlpacaTransaction? alpacaTransaction in JsonSerializer.DeserializeAsyncEnumerable<AlpacaTransaction>(readFilestream, options))
                {
                    // Ignore any failed AlpacaTransaction de-serialisations
                    if (alpacaTransaction is null)
                    {
                        continue;
                    }

                    // SAve each transaction as it is de-serialised
                    transactions.Add(alpacaTransaction);

                    // Increment the progress counter and calculate progress percent
                    processed++;

                    // Update the progress UI every 100 transactions read
                    if (processed % 100 == 0 || processed == totalTransactions)
                    {
                        replayProgress = 100.0 * processed / totalTransactions;
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }

            // SAve the extracted transactions to current state
            State.ReplayTransactions = transactions;

            // Force the progress bar to 100%
            replayProgress = 100.0;
            await InvokeAsync(StateHasChanged);

            // Navigate to the home page to show the logging screen
            Navigation.NavigateTo("/");

            // Notify what we are doing
            Logger.LogMessage("ReplayTransactions", $"Replaying {transactions.Count} transactions from: {selectedFile} Target device type: {State.ReplayTargetDevice?.DeviceType}");

            // Create an HTTP client to send commands to the selected device
            HttpClient client = HttpClientFactory.CreateClient();

            // Create a regex to extract the device type and method from the request URI.
            Regex uriRegex = new Regex(@"\/api\/v1\/(?<DeviceTypeString>[^\/]+)\/\d+\/(?<Method>[^\/\?]+)", RegexOptions.IgnoreCase);

            // Set time counters for the original file and the current playback
            TimeSpan timeSinceRecodingStart = TimeSpan.FromSeconds(0.0);
            TimeSpan timeSincePlaybackStart = TimeSpan.FromSeconds(0.0);

            // Initialise start times for the recoding and playback
            DateTime startOfRecording = transactions.Count > 0 ? transactions[0].RequestTimeSent : DateTime.MinValue;  // Initialise the time at which the original recording started from the first transaction if it exists
            DateTime startOfPlayback = DateTime.Now; // Initialise the time at which playback started

            Logger.Newlines(1);

            // Send each recorded item to the selected device in turn and log the outcome
            foreach (AlpacaTransaction transaction in transactions)
            {
                timeSinceRecodingStart = transaction.RequestTimeSent - startOfRecording;
                timeSincePlaybackStart = DateTime.Now - startOfPlayback;

                // Calculate the required delay in integer milliseconds, which is the time between this and the last transaction
                int delayMs = (int)timeSinceRecodingStart.Subtract(timeSincePlaybackStart).TotalMilliseconds;
                Logger.LogDebug("ReplayTransactions", $"Txn time: {transaction.RequestTimeSent:HH:mm:ss.fff}, Calculated delay: {delayMs:0.0} milliseconds. Time since recording start: {timeSinceRecodingStart.TotalSeconds:0.000}," +
                    $" Time since playback start: {timeSincePlaybackStart.TotalSeconds:0.000}");

                // Apply the delay if it is positive
                await Task.Delay(delayMs >= 0 ? delayMs : 0);

                // Get the method being called
                Match match = uriRegex.Match(transaction.RequestUri ?? string.Empty);

                // Check whether we got a value
                string methodName = "UnknownMethod";
                if (match.Success) // Got a match OK
                {
                    // Extract the device type as a string
                    methodName = match.Groups["Method"].Value;
                }

                // Create the target URI based on the targe device's IP address, port and Alpaca device number
                string targetUri = $"http://{State.ReplayTargetDevice?.IpAddress}:{State.ReplayTargetDevice?.PortNumber}{transaction.RequestUri}";

                // Create the outgoing log message and save it for use if the device responds differently to the recorded outcome
                sendLogMessage = $"──► {transaction.RequestMethod} {CapitaliseMemberName(methodName)} - {targetUri}";

                // Remember the device send time in case a mismatch occurs
                DateTime responseTime = DateTime.Now;

                // Write the outgoing log message
                Logger.LogMessage("ReplayTransactions", sendLogMessage);

                // Construct an HTTP request for the target device
                HttpRequestMessage request = new HttpRequestMessage(new HttpMethod(transaction.RequestMethod), targetUri);

                // If the transaction contains a request body, add it and this transaction's content headers to the request
                if (transaction.RequestBody != "") // The transaction does have a request body
                {
                    // Create a string content item based on the transaction's content
                    Logger.LogDebug("ReplayTransactions", $"Request body is not empty string: {transaction.RequestBody}.");
                    StringContent newContent = new StringContent(transaction.RequestBody, System.Text.Encoding.UTF8, "application/x-www-form-urlencoded");

                    // Check whether there is an existing content item (satisfied nullability requirements)
                    if (request.Content is not null) // There is a request body so add it's headers to the original request
                    {
                        // Iterate over the headers and add them to the new content
                        foreach (KeyValuePair<string, IEnumerable<string>> header in request.Content.Headers)
                        {
                            // Copy header values to the new content (TryAddWithoutValidation is used to avoid validation issues)
                            newContent.Headers.TryAddWithoutValidation(header.Key, header.Value);
                            Logger.LogDebug("ReplayTransactions", $"Added header: {header.Key} = {header.Value}.");
                        }
                    }

                    // Add the revised content to the request
                    request.Content = newContent;
                    Logger.LogDebug("ReplayTransactions", $"Added content: {transaction.RequestBody}.");
                }

                // Add any recorded request headers (as opposed to content headers) to the outgoing HttpRequestMessage.
                if (transaction.RequestHeaders != null)
                {
                    // Try to add each request header to request.Headers .
                    foreach (KeyValuePair<string, string[]> kvp in transaction.RequestHeaders)
                    {
                        var headerName = kvp.Key;
                        var headerValues = kvp.Value ?? Array.Empty<string>();

                        // Try general headers first
                        if (request.Headers.TryAddWithoutValidation(headerName, headerValues)) // Added header OK
                            Logger.LogDebug("ReplayTransactions", $"Added {kvp.Key} request header successfully.");
                    }
                }

                // Send the request to the target device and wait for a response
                await client.SendAsync(request).ContinueWith(async responseTask =>
                {
                    try
                    {
                        var response = await responseTask;
                        string responseString = await response.Content.ReadAsStringAsync();
                        string formattedString = responseString;

                        // Pretty-print the device's current response
                        try
                        {
                            if (Settings.PlaybackExpandJson)
                            {
                                formattedString = JsonSerializer.Serialize(JsonSerializer.Deserialize<object>(responseString), new JsonSerializerOptions
                                {
                                    WriteIndented = true,
                                    Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
                                });
                            }
                        }
                        catch (Exception)
                        {
                            // Do nothing, formattedString retains its original value: responseString
                        }

                        // Create the incoming log message and save it for use if the device responds differently to the recorded outcome
                        responseLogMessage = $"◄── {response.StatusCode} {formattedString}";
                        Logger.LogMessage("ReplayTransactions", responseLogMessage);

                        // Pretty-print the original response
                        try
                        {
                            formattedString = JsonSerializer.Serialize(transaction.Response, new JsonSerializerOptions()
                            {
                                WriteIndented = Settings.PlaybackExpandJson,
                                Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
                            });
                        }
                        catch (Exception ex)
                        {
                            formattedString = $"Pretty-print failure - could not display original response: {ex.Message}.";
                        }

                        // If the response status is 200 OK, assess the device response's "Value", "ErrorNumber", and "ErrorMessage" properties against those in the original response.
                        if (response.StatusCode == System.Net.HttpStatusCode.OK && transaction.Response != null)
                        {
                            try
                            {
                                // Define a list of JSON element names to check for equivalence between the recorded response and the current response
                                using JsonDocument currentDoc = JsonDocument.Parse(responseString);

                                // Check each JSON name in turn
                                foreach (string propertyName in RESPONSE_PROPERTIES_TO_COMARE)
                                {
                                    // Determine whether the JSON name exists in the original and current responses
                                    bool originalExists = transaction.Response.RootElement.TryGetProperty(propertyName, out JsonElement originalElem);
                                    bool currentExists = currentDoc.RootElement.TryGetProperty(propertyName, out JsonElement currentElem);

                                    // Handle different combinations of elements being present and not present
                                    if (originalExists && currentExists) // Command returns this element in both cases
                                    {
                                        if (Regex.Replace(originalElem.GetRawText(), @"\s+", "") == Regex.Replace(currentElem.GetRawText(), @"\s+", "")) // Elements match exactly
                                        {
                                            // Report when the Value elements match but don't report when ErrorMessage and ErrorNumber match just to cut down log noise
                                            if (propertyName.ToUpperInvariant() == "VALUE")
                                                Logger.LogMessage("ReplayTransactions", $"    {propertyName} elements match.");
                                        }
                                        else // Elements are different
                                        {
                                            HandleMismatch(responseTime, propertyName, sendLogMessage, responseLogMessage, VALUES_DIFFERENT_MESSAGE, originalElem, currentElem);
                                        }
                                    }
                                    else if (originalExists != currentExists) // One call returned this JSON element while the other did not...
                                    {
                                        HandleMismatch(responseTime, propertyName, sendLogMessage, responseLogMessage, ELEMENT_MISSING_IN_ONE_RESPONSE, originalElem, currentElem);

                                    }
                                    else // Neither response contained the required element
                                    {
                                        // Handle Value as a special case because it can legitimately be absent in a method response
                                        if (propertyName.ToUpperInvariant() == "VALUE")
                                        {
                                            Logger.LogMessage("ReplayTransactions", "    Method - no Value element.");
                                        }
                                        else // Other elements are expected always to be present
                                        {
                                            HandleMismatch(responseTime, propertyName, sendLogMessage, responseLogMessage, ELEMENT_MISSING_IN_BOTH_RESPONSES, originalElem, currentElem);
                                        }
                                    }
                                }

                                Logger.Newlines(1);
                            }
                            catch (Exception ex)
                            {
                                Logger.LogError("ReplayTransactions", $"Error assessing response to transaction {transaction.RequestUri}: {ex.Message}\r\n{ex}");
                            }
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogError("ReplayTransactions", $"Error sending request for {transaction.RequestUri}: {ex.Message}\r\n{ex}");
                        await DialogService.Alert($"Error while sending request or processing response, see Home page for details: {ex.Message}", "Unable to Replay", null);
                    }
                });

                // End of processing this transaction - Exit if cancellation is requested
                if (State.CancellationToken.IsCancellationRequested)
                {
                    Logger.LogError("ReplayTransactions", $"Replay cancelled.");
                    break;
                }
            }

            // All transactions have been processed - report any mis-matches
            int mismatchCount = Mismatches.Count;
            if (mismatchCount > 0) // 1 or more mis-matches found
            {
                // Log the number of mismatches found
                Logger.LogMessage("", $"There {(mismatchCount == 1 ? "was" : "were")} {mismatchCount} mismatch{(mismatchCount == 1 ? "" : "es")} including:");

                foreach (string message in ReplayMismatchMessages)
                {
                    int messageCount = Mismatches.Where((m) => m.MismatchMessage == message).Count();
                    Logger.LogMessage("ReplayTransactions", $"    {messageCount} \"{message}\" message{(messageCount == 1 ? "" : "s")}.");
                }
                Logger.Newlines(1);

                // List any mismatches
                int issueCount = 1;
                foreach (Mismatch mismatch in Mismatches)
                {
                    Logger.LogMessage("ReplayTransactions", $"Mismatch {issueCount} at replay time: {mismatch.MismatchTime:HH:mm:ss.fff}");
                    Logger.LogMessage("ReplayTransactions", $"{mismatch.SendLogMessage}");
                    Logger.LogMessage("ReplayTransactions", $"{mismatch.ResponseLogMessage}");
                    Logger.LogMessage("ReplayTransactions", $"    {mismatch.PropertyName.ToUpperInvariant()} {mismatch.MismatchMessage}");
                    Logger.LogMessage("ReplayTransactions", $"      Original: {mismatch.OriginalJsonString}");
                    Logger.LogMessage("ReplayTransactions", $"      Current:  {mismatch.CurrentJsonString}");
                    Logger.Newlines(1);
                    issueCount++;
                }
            }
            else // No mis-matches found
            {
                Logger.LogMessage("ReplayTransactions", "There were no mismatches");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError("ReplayTransactions", $"Error replaying file '{selectedFile}': {ex.Message}\r\n{ex}");
            await DialogService.Alert($"Error while replaying, see Home page for details: {ex.Message}", "Unable to Replay", null);
        }
    }

    /// <summary>
    /// Normalize a path to a full path without a trailing directory separator.
    /// Returns an empty string for null/empty input.
    /// </summary>
    string NormalizePath(string? path)
    {
        if (string.IsNullOrEmpty(path)) return string.Empty;
        try
        {
            var fp = Path.GetFullPath(path);
            return fp.TrimEnd(Path.DirectorySeparatorChar);
        }
        catch
        {
            return path.TrimEnd(Path.DirectorySeparatorChar);
        }
    }

    /// <summary>
    /// Return the (cached) list of subdirectories for <paramref name="path"/>.
    /// Results are normalized and cached to avoid repeated IO.
    /// </summary>
    IEnumerable<string> GetDirectoriesCached(string path)
    {
        var key = NormalizePath(path);
        if (!dirCache.TryGetValue(key, out var list))
        {
            var raw = Browser.GetDirectories(path)?.ToList() ?? new List<string>();
            // normalize child paths for consistency
            list = raw.Select(d => NormalizePath(d)).ToList();
            dirCache[key] = list;
        }
        return dirCache[key];
    }

    /// <summary>
    /// Toggle expanded/collapsed state for the specified <paramref name="path"/>.
    /// </summary>
    void ToggleExpand(string path)
    {
        var key = NormalizePath(path);
        if (expanded.Contains(key))
            expanded.Remove(key);
        else
            expanded.Add(key);
    }

    void SelectTargetDevice(AlpacaSpy.Models.ConfiguredDevice device)
    {
        State.ReplayTargetDevice = device;
    }

    /// <summary>
    /// Returns true when the specified <paramref name="path"/> is marked expanded.
    /// </summary>
    bool IsExpanded(string path) => expanded.Contains(NormalizePath(path));

    /// <summary>
    /// Switch the tree to show the user's Documents folder as the base and select it.
    /// </summary>
    void ShowDocuments()
    {
        var docs = Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments);
        if (!string.IsNullOrEmpty(docs) && Directory.Exists(docs))
        {
            baseIsDisks = false;
            baseRootPath = docs;
            dirCache.Clear();
            expanded.Clear();
            State.ReplaySelectedFileFullName = null;

            // Show the Documents folder itself as the root (do not auto-select a child)
            NavigateTo(docs);
            // ensure the root is expanded so children are visible
            expanded.Add(NormalizePath(docs));
            _ = GetDirectoriesCached(docs);
        }
    }

    /// <summary>
    /// Switch the tree to show system drives (Disks) as the base and select the first drive if present.
    /// </summary>
    void ShowDisks()
    {
        baseIsDisks = true;
        baseRootPath = null;
        dirCache.Clear();
        expanded.Clear();
        State.ReplaySelectedFileFullName = null;

        // Select the first drive if present
        var firstDrive = DriveInfo.GetDrives().FirstOrDefault();
        if (firstDrive != null && Directory.Exists(firstDrive.Name))
        {
            SelectPath(firstDrive.Name);
        }
    }

    void ShowAscomLogsClickHandler()
    {
        ShowAscomLogs(true);
    }

    /// <summary>
    /// Switch the tree to the ASCOM logs directory (via TraceLogger) and select the first visible child.
    /// Falls back to the Disks view if the ASCOM log path is unavailable.
    /// </summary>
    void ShowAscomLogs(bool clearSelectedFile)
    {
        try
        {
            var dir = TraceLogger.GetDefaultLogFilePath(DateTime.Now);
            // If TraceLogger returns a file path rather than a directory, get its directory
            if (!string.IsNullOrEmpty(dir) && File.Exists(dir))
            {
                dir = Path.GetDirectoryName(dir) ?? dir;
            }
            baseIsDisks = false;
            baseRootPath = dir;
            dirCache.Clear();
            expanded.Clear();
            if (clearSelectedFile)
            {
                State.ReplaySelectedFileFullName = null;

            }
            // Select the first child under ASCOM logs, or the directory itself if no children
            if (!string.IsNullOrEmpty(dir) && Directory.Exists(dir))
            {
                var children = GetDirectoriesCached(dir).ToList();
                if (children.Any())
                {
                    SelectPath(children.First());
                }
                else
                {
                    SelectPath(dir);
                }
            }
        }
        catch
        {
            // fallback to disks if ASCOM.Tools isn't available or call fails
            baseIsDisks = true;
            baseRootPath = null;
            dirCache.Clear();
            expanded.Clear();
            State.ReplaySelectedFileFullName = null;

            var firstDrive = DriveInfo.GetDrives().FirstOrDefault();
            if (firstDrive != null && Directory.Exists(firstDrive.Name))
            {
                SelectPath(firstDrive.Name);
            }
        }
    }

    /// <summary>
    /// Select the specified directory path, update breadcrumb and load JSON files in that directory.
    /// </summary>
    void SelectPath(string path)
    {
        if (Directory.Exists(path))
        {
            SelectedPath = path;
            BuildBreadcrumb(path);

            Files = new List<System.IO.FileInfo>();
            foreach (var f in Browser.GetFiles(path))
            {
                if (f != null && f.EndsWith(".json", StringComparison.OrdinalIgnoreCase))
                {
                    Files.Add(new System.IO.FileInfo(f));
                }
            }
        }
    }

    /// <summary>
    /// Handle radio selection changes for JSON files. Updates the currently selected file full path.
    /// </summary>
    void OnFileRadioChanged(string fullName, ChangeEventArgs e)
    {
        // Radio change value can be string or bool; treat any change as selection of this radio button.
        if (e?.Value is bool b && b == false)
        {
            // some browsers/components may allow un-checking; treat as no selection
            State.ReplaySelectedFileFullName = null;
        }
        else
        {
            State.ReplaySelectedFileFullName = fullName;
        }
    }

    /// <summary>
    /// Handles a mismatch between the original and current JSON responses.
    /// </summary>
    /// <param name="mismatchTime">The time the mismatch was detected.</param>
    /// <param name="propertyName">The name of the property that mismatched.</param>
    /// <param name="sendLogMessage">The log message for the sent request.</param>
    /// <param name="responseLogMessage">The log message for the received response.</param>
    /// <param name="mismatchDescription">A description of the mismatch.</param>
    /// <param name="originalJsonResponse">The original JSON response.</param>
    /// <param name="currentJsonResponse">The current JSON response.</param>
    void HandleMismatch(DateTime mismatchTime, string propertyName, string sendLogMessage, string responseLogMessage, string mismatchDescription, JsonElement originalJsonResponse, JsonElement currentJsonResponse)
    {
        string originalJsonString = GetDisplayString(originalJsonResponse);
        string currentJsonString = GetDisplayString(currentJsonResponse);

        // Log the mismatch message
        Logger.LogMessage("ReplayTransactions", $"    {propertyName.ToUpperInvariant()} {mismatchDescription}");
        Logger.LogMessage("ReplayTransactions", $"      Original: {originalJsonString}");
        Logger.LogMessage("ReplayTransactions", $"      Current:  {currentJsonString}");

        // Add the mismatch record to the list for later display
        Mismatches.Add(new Mismatch(mismatchTime, sendLogMessage, responseLogMessage, originalJsonString, currentJsonString, mismatchDescription, propertyName));
    }

    /// <summary>
    /// Formats a JSON element for display, pretty-printing objects and arrays.
    /// </summary>
    /// <param name="element">The JSON element to format.</param>
    /// <returns>A formatted string representation of the JSON element.</returns>
    string GetDisplayString(JsonElement element)
    {
        if (element.ValueKind == JsonValueKind.Object || element.ValueKind == JsonValueKind.Array)
        {
            return JsonSerializer.Serialize(element, new JsonSerializerOptions
            {
                WriteIndented = true,
                Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
            });
        }
        return element.GetRawText();
    }

    /// <summary>
    /// Formats a JSON element into a string of name-value pairs.
    /// </summary>
    /// <param name="element">The JSON element to format.</param>
    /// <returns>A string representation of the JSON element's name-value pairs.</returns>
    string FormatJsonNameValuePairs(JsonElement element)
    {
        if (element.ValueKind == JsonValueKind.Object)
        {
            List<string> parts = new();

            foreach (JsonProperty property in element.EnumerateObject())
            {
                parts.Add($"{property.Name}:{FormatJsonNameValuePairs(property.Value)}");
            }

            return string.Join(", ", parts);
        }

        if (element.ValueKind == JsonValueKind.Array)
        {
            List<string> parts = new();

            foreach (JsonElement item in element.EnumerateArray())
            {
                parts.Add(FormatJsonNameValuePairs(item));
            }

            return string.Join(", ", parts);
        }

        return element.GetRawText();
    }

    /// <summary>
    /// Creates a correctly capitalised version of the member's name
    /// </summary>
    /// <param name="input">The member name to capitalise.</param>
    /// <returns>The capitalised member name.</returns>
    string CapitaliseMemberName(string input)
    {
        if (string.IsNullOrEmpty(input))
            return input;

        // Try to find the member name in the MemberNames enum in order to get its correctly capitalised version
        try
        {
            // Return the correctly cased member name
            return Enum.Parse<MemberNames>(input, true).ToString();
        }
        catch
        {
            // If the enum parse fails just capitalise the first letter
            return char.ToUpper(input[0]) + input.Substring(1);
        }
    }

    /// <summary>
    /// Renders a directory and its children as a tree structure.
    /// </summary>
    /// <param name="path">The path of the directory to render.</param>
    /// <returns>A RenderFragment representing the directory tree.</returns>
    RenderFragment RenderDirectory(string path) => builder =>
    {
        // simple recursive renderer: shows one level and an expander if children exist
        var seq = 0;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "tree-node");

        var hasChildren = GetDirectoriesCached(path).Any();
        if (hasChildren)
        {
            builder.OpenElement(seq++, "button");
            builder.AddAttribute(seq++, "class", "expander");
            builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => ToggleExpand(path)));
            builder.AddContent(seq++, IsExpanded(path) ? "▼" : "▶");
            builder.CloseElement();
        }
        else
        {
            // render a fixed-width placeholder so labels align with items that have an expander
            builder.OpenElement(seq++, "span");
            builder.AddAttribute(seq++, "class", "expander-placeholder");
            builder.CloseElement();
        }

        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", "node-label");
        builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => SelectPath(path)));
        builder.AddContent(seq++, Path.GetFileName(path));
        builder.CloseElement();

        if (IsExpanded(path) && hasChildren)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "children");
            builder.AddAttribute(seq++, "style", "margin-left:16px");
            foreach (var child in GetDirectoriesCached(path))
            {
                builder.AddContent(seq++, RenderDirectory(child));
            }
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    /// <summary>
    /// Build the breadcrumb parts for the given <paramref name="path"/>.
    /// </summary>
    /// <param name="path">The path for which to build the breadcrumb.</param>
    void BuildBreadcrumb(string path)
    {
        BreadcrumbParts.Clear();

        var parts = path.Split(Path.DirectorySeparatorChar, StringSplitOptions.RemoveEmptyEntries);

        string current = Path.GetPathRoot(path) ?? "";

        BreadcrumbParts.Add(new Crumb(current, current));

        foreach (var part in parts.Skip(1))
        {
            current = Path.Combine(current, part);
            BreadcrumbParts.Add(new Crumb(part, current));
        }
    }

    /// <summary>
    /// Navigates to the specified path, updating the selected path, breadcrumb, and file list.
    /// </summary>
    /// <param name="path">The path to navigate to.</param>
    void NavigateTo(string path)
    {
        SelectedPath = path;
        BuildBreadcrumb(path);

        Files = new List<System.IO.FileInfo>
        ();
        foreach (var f in Browser.GetFiles(path))
        {
            if (f != null && f.EndsWith(".json", StringComparison.OrdinalIgnoreCase))
            {
                Files.Add(new System.IO.FileInfo(f));
            }
        }

        // ensure the tree shows the selected folder: expand its ancestors and cache their contents
        ExpandAncestors(path);

        // make sure the selected node itself is expanded so its children are visible
        var normPath = NormalizePath(path);
        expanded.Add(normPath);

        // Force refresh of parent's child list so UI re-renders with updated entries
        try
        {
            var parent = Directory.GetParent(path);
            if (parent != null)
            {
                var parentKey = NormalizePath(parent.FullName);
                // remove cached children for parent to force re-fetch
                dirCache.Remove(parentKey);
                // prefetch updated children
                _ = GetDirectoriesCached(parent.FullName);
                // ensure parent is marked expanded so its children are shown
                expanded.Add(parentKey);
            }
        }
        catch { }

        // clear any previous selection when navigating so radios are initially unselected
        State.ReplaySelectedFileFullName = null;

        // request UI update
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Navigates to the parent directory of the currently selected path.
    /// </summary>
    void GoUpOneLevel()
    {
        if (string.IsNullOrEmpty(SelectedPath))
            return;

        var parent = Directory.GetParent(SelectedPath);
        if (parent != null)
        {
            NavigateTo(parent.FullName);
        }
    }

    /// <summary>
    /// Expands all ancestor directories of the specified path, ensuring they are visible in the UI.
    /// </summary>
    /// <param name="path">The path whose ancestors should be expanded.</param>
    void ExpandAncestors(string path)
    {
        try
        {
            // walk up from the path to root (or to baseRootPath when baseIsDisks == false)
            var p = Directory.GetParent(path);
            while (p != null)
            {
                var key = NormalizePath(p.FullName);

                // stop if we've reached the baseRootPath when in Documents/ASCOM mode
                if (!baseIsDisks && !string.IsNullOrEmpty(baseRootPath))
                {
                    if (string.Equals(NormalizePath(p.FullName), NormalizePath(baseRootPath), StringComparison.OrdinalIgnoreCase))
                    {
                        expanded.Add(key);
                        // ensure children cached
                        _ = GetDirectoriesCached(p.FullName);
                        break;
                    }
                }

                expanded.Add(key);
                // ensure children cached
                _ = GetDirectoriesCached(p.FullName);

                p = Directory.GetParent(p.FullName);
            }
        }
        catch
        {
            // ignore any IO issues while expanding
        }
    }
}
